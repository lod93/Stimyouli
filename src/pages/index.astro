---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LinkCard from '../components/LinkCard.astro';
---

<Layout title="Engineering & Infrastructure" description="Stimyouli Group - Cairo-based engineering and infrastructure company building scalable web systems, SaaS platforms, and cloud services.">
	<Navigation />
	
	<main class="max-w-7xl mx-auto px-6 pt-24 pb-32">
		<!-- Hero Section -->
		<section class="py-20 md:py-32">
			<div class="max-w-3xl">
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neon-cyan/10 border border-neon-cyan/20 mb-8">
					<span class="relative flex h-2 w-2">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-cyan opacity-75"></span>
						<span class="relative inline-flex rounded-full h-2 w-2 bg-neon-cyan"></span>
					</span>
					<span class="text-[10px] font-bold tracking-widest text-neon-cyan uppercase">Now Indexing for 2026</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl font-bold leading-[1.1] mb-8 text-gradient">
					Building Scalable <br/>
					<span class="text-neon-cyan">Digital Ecosystems</span>
				</h1>
				
				<p class="text-xl text-gray-400 leading-relaxed max-w-2xl mb-12">
					Stimyouli Group is a Cairo-based engineering and infrastructure powerhouse specializing in high-performance web systems, SaaS platforms, and cloud services. We bridge the gap between complex engineering and real-world business impact.
				</p>
				
				<div class="flex flex-wrap gap-4">
					<a href="/stimyouli-public-repo/services" class="bg-neon-cyan text-true-black px-8 py-4 rounded-full font-bold hover:bg-white transition-colors">
						View Services
					</a>
					<a href="/stimyouli-public-repo/portfolio" class="px-8 py-4 rounded-full font-bold text-white border border-white/10 hover:bg-white/5 transition-colors">
						See Portfolio
					</a>
				</div>
			</div>
		</section>

		<!-- Ecosystem Grid -->
		<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<LinkCard 
				tag="Engineering & Growth" 
				title="Stimyouli.com" 
				description="Core software engineering agency building Next.js platforms, real-time automation, and SEO-optimized architectures."
				href="/stimyouli-public-repo/services"
			/>
			<LinkCard 
				tag="Infrastructure" 
				title="1100.website" 
				description="High-performance global web hosting and NVMe-powered cloud infrastructure with 99.9% uptime."
				href="https://1100.website"
			/>
			<LinkCard 
				tag="Cloud Hosting" 
				title="Jabalhost.com" 
				description="Professional VPS and dedicated server hosting for demanding enterprise workloads and digital products."
				href="https://jabalhost.com"
			/>
			<LinkCard 
				tag="SaaS Platform" 
				title="Aklatix.cloud" 
				description="Cloud-based Point of Sale (POS) and business management system for real-time inventory and operations."
				href="https://aklatix.cloud"
			/>
			<LinkCard 
				tag="Digital Commerce" 
				title="Be3.click" 
				description="Scalable marketplace and digital commerce infrastructure for modern retail and market entry."
				href="https://be3.click"
			/>
		</section>

		<!-- Principles Section -->
		<section class="mt-40 border-t border-white/5 pt-20">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-20">
				<div>
					<h2 class="text-3xl font-bold mb-6">Architecture Principles</h2>
					<p class="text-gray-400 mb-8 leading-relaxed">
						We design and deploy production-grade systems focused on performance, lower-latency, and global scalability.
					</p>
					<ul class="space-y-4">
						<li class="flex items-center gap-3 text-gray-300">
							<div class="w-1.5 h-1.5 rounded-full bg-neon-cyan"></div>
							Performance-first design
						</li>
						<li class="flex items-center gap-3 text-gray-300">
							<div class="w-1.5 h-1.5 rounded-full bg-neon-cyan"></div>
							Mobile-first UI/UX
						</li>
						<li class="flex items-center gap-3 text-gray-300">
							<div class="w-1.5 h-1.5 rounded-full bg-neon-cyan"></div>
							Modular and scalable systems
						</li>
					</ul>
				</div>
				<div class="glass-card flex flex-col justify-center text-center">
					<div class="text-5xl font-bold text-neon-cyan mb-2">99.9%</div>
					<div class="text-sm font-bold uppercase tracking-widest text-gray-500">Infrastructure Uptime</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
