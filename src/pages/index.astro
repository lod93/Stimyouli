---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import LinkCard from '../components/LinkCard.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Engineering & Ecosystem" description="Stimyouli Group: Modern software engineering, global hosting, and SaaS infrastructure.">
	<Navigation />
	
	<main class="max-w-7xl mx-auto px-6">
		<!-- Hero Section -->
		<section class="py-40 flex flex-col items-start gap-8">
			<div class="inline-block px-4 py-2 rounded-full bg-neon-cyan/10 border border-neon-cyan/20 text-neon-cyan text-xs font-bold uppercase tracking-widest mb-4">
				Established 2024
			</div>
			<h1 class="text-8xl font-black text-white tracking-tighter leading-[0.85] max-w-4xl">
				ENGINEERING<br/>
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-white/40">INFRASTRUCTURE</span><br/>
				ECOSYSTEM
			</h1>
			
			<div class="max-w-2xl mt-8">
				<p class="text-gray-400 text-2xl font-medium leading-relaxed mb-12">
					Stimyouli Group is a Cairo-based digital conglomerate specializing in <span class="text-white">Software Engineering</span>, <span class="text-white">Global Hosting</span>, and <span class="text-white">Cloud SaaS</span>.
				</p>
				
				<div class="flex flex-wrap gap-6">
					<a href={`${base}/services`} class="bg-white text-true-black px-10 py-5 rounded-2xl font-bold hover:bg-neon-cyan transition-all duration-300 hover:scale-[1.02] shadow-xl">
						Our Services
					</a>
					<a href={`${base}/portfolio`} class="px-10 py-5 rounded-2xl font-bold text-white border border-white/10 hover:bg-white/5 transition-all duration-300">
						Explore Portfolio
					</a>
				</div>
			</div>
		</section>

		<!-- Ecosystem Grid -->
		<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<LinkCard tag="Engineering & Growth" title="Stimyouli.com" description="Core agency building Next.js platforms, real-time automation, and SEO-optimized architectures." href={`${base}/services`}></LinkCard>
			<LinkCard tag="Infrastructure" title="1100.website" description="High-performance global web hosting and NVMe-powered cloud infrastructure." href="https://1100.website"></LinkCard>
			<LinkCard tag="SaaS Platform" title="Aklatix.cloud" description="Cloud POS and real-time inventory management platform." href="https://aklatix.cloud"></LinkCard>
			<LinkCard tag="Digital Commerce" title="Be3.click [Under Construction]" description="Scalable marketplace and digital commerce infrastructure." href="https://be3.click"></LinkCard>
			<LinkCard tag="Cloud Hosting" title="Jabalhost.com" description="Professional VPS and dedicated enterprise server hosting." href="https://jabalhost.com"></LinkCard>
		</section>

		<!-- Principles Section -->
		<section class="mt-40 border-t border-white/5 pt-20">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-20">
				<div>
					<h2 class="text-3xl font-bold mb-6">Architecture Principles</h2>
					<p class="text-gray-500 text-lg leading-relaxed">
						We build on a stateless, performance-first foundation. Every system within the Stimyouli ecosystem is designed for high concurrency and low latency, utilizing modern stacks like Next.js, Node.js, and Flask.
					</p>
				</div>
				<div class="grid grid-cols-2 gap-8">
					<div class="p-8 rounded-3xl bg-white/5 border border-white/5">
						<div class="text-4xl font-black text-neon-cyan mb-2">99.9%</div>
						<div class="text-xs uppercase tracking-widest font-bold text-gray-500">Uptime Reliability</div>
					</div>
					<div class="p-8 rounded-3xl bg-white/5 border border-white/5">
						<div class="text-4xl font-black text-neon-cyan mb-2">24/7</div>
						<div class="text-xs uppercase tracking-widest font-bold text-gray-500">Managed Support</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
