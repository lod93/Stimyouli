---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Company Profile" description="Mission, structure, and engineering philosophy of Stimyouli Group.">
	<Navigation />
	
	<main class="max-w-4xl mx-auto px-6 py-40">
		<h1 class="text-7xl font-black mb-16 text-white tracking-tighter">Company Profile</h1>
		
		<section class="mb-32">
			<h2 class="text-2xl font-bold mb-8 text-white uppercase tracking-widest opacity-50">About the Group</h2>
			<div class="prose prose-invert max-w-none text-gray-400 leading-relaxed text-xl font-medium">
				<p>
					Stimyouli Group is a digital conglomerate providing a full suite of services for the modern digital landscape. Founded on the principle that <span class="text-neon-cyan drop-shadow-[0_0_15px_rgba(0,242,255,0.2)]">"brilliant engineering meets compelling storytelling,"</span> the group manages multiple brands across hosting, SaaS, and creative services.
				</p>
			</div>
		</section>

		<section class="mb-32">
			<h2 class="text-2xl font-bold mb-12 text-white uppercase tracking-widest opacity-50">Our Brands</h2>
			<div class="space-y-6">
				<div class="p-10 rounded-[2rem] bg-true-black border border-white/5 hover:border-white/10 transition-colors">
					<h3 class="text-2xl font-bold text-white mb-3">Stimyouli.com</h3>
					<p class="text-gray-500 text-lg">Flagship creative and development agency. Expert in Next.js, React, and high-concurrency Node.js/Flask systems.</p>
				</div>
				<div class="p-10 rounded-[2rem] bg-true-black border border-white/5 hover:border-white/10 transition-colors">
					<h3 class="text-2xl font-bold text-white mb-3">1100.website & Jabalhost.com</h3>
					<p class="text-gray-500 text-lg">Performance-first infrastructure providers. NVMe storage, LiteSpeed optimization, and 99.9% uptime.</p>
				</div>
				<div class="p-10 rounded-[2rem] bg-true-black border border-white/5 hover:border-white/10 transition-colors">
					<h3 class="text-2xl font-bold text-white mb-3">Aklatix.cloud</h3>
					<p class="text-gray-500 text-lg">Premier cloud-based Point of Sale (POS) and inventory management SaaS.</p>
				</div>
			</div>
		</section>

		<section class="mt-40 border-t border-white/5 pt-20">
			<h2 class="text-2xl font-bold mb-12 text-white uppercase tracking-widest opacity-50">Contact Information</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-gray-500 text-lg">
				<div>
					<p class="font-bold text-white mb-3 uppercase tracking-widest text-xs">Enquiries</p>
					<p class="text-neon-cyan font-bold">info@stimyouli.com</p>
				</div>
				<div>
					<p class="font-bold text-white mb-3 uppercase tracking-widest text-xs">Headquarters</p>
					<p>Cairo, Egypt</p>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
