---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Company Profile" description="Mission, structure, and engineering philosophy of Stimyouli Group.">
	<Navigation />
	
	<main class="max-w-4xl mx-auto px-6 py-24">
		<h1 class="text-5xl font-bold mb-12 text-gradient tracking-tight">Company Profile</h1>
		
		<section class="mb-20">
			<h2 class="text-2xl font-bold mb-6 text-white">🏢 About the Group</h2>
			<div class="prose prose-invert max-w-none text-gray-400 leading-relaxed text-lg">
				<p>
					Stimyouli Group is a digital conglomerate providing a full suite of services for the modern digital landscape. Founded on the principle that <span class="text-neon-cyan">"brilliant engineering meets compelling storytelling,"</span> the group manages multiple brands across hosting, SaaS, and creative services.
				</p>
			</div>
		</section>

		<section class="mb-20">
			<h2 class="text-2xl font-bold mb-6 text-white">💼 Our Brands</h2>
			<div class="space-y-8">
				<div class="p-8 rounded-2xl bg-white/5 border border-white/5">
					<h3 class="text-xl font-bold text-neon-cyan mb-2">Stimyouli.com</h3>
					<p class="text-gray-400">Flagship creative and development agency. Expert in Next.js, React, and high-concurrency Node.js/Flask systems.</p>
				</div>
				<div class="p-8 rounded-2xl bg-white/5 border border-white/5">
					<h3 class="text-xl font-bold text-neon-cyan mb-2">1100.website & Jabalhost.com</h3>
					<p class="text-gray-400">Performance-first infrastructure providers. NVMe storage, LiteSpeed optimization, and 99.9% uptime.</p>
				</div>
				<div class="p-8 rounded-2xl bg-white/5 border border-white/5">
					<h3 class="text-xl font-bold text-neon-cyan mb-2">Aklatix.cloud</h3>
					<p class="text-gray-400">Premier cloud-based Point of Sale (POS) and inventory management SaaS.</p>
				</div>
			</div>
		</section>

		<section class="mt-20 border-t border-white/5 pt-12">
			<h2 class="text-2xl font-bold mb-6 text-white">✉️ Contact Information</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-gray-400">
				<div>
					<p class="font-bold text-white mb-2">Enquiries</p>
					<p>info@stimyouli.com</p>
				</div>
				<div>
					<p class="font-bold text-white mb-2">Headquarters</p>
					<p>Cairo, Egypt</p>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
