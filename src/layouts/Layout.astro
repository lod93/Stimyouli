---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Stimyouli Group - Software Engineering & Infrastructure" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="bg-true-black text-white antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Stimyouli Group</title>
		
		<!-- LLM & Search Indexing -->
		<link rel="alternate" type="application/ld+json" href={`${base}/metadata.jsonld`} title="Organization Metadata" />
		<link rel="alternate" type="text/plain" href={`${base}/llms.txt`} title="LLM-friendly content" />
		
		<!-- Social Previews -->
		<meta property="og:title" content={`${title} | Stimyouli Group`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={`${base}/social-preview.png`} />
		<meta name="twitter:card" content="summary_large_image" />
		
    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@700;800;900&display=swap" rel="stylesheet">
	</head>
	<body class="selection:bg-neon-cyan selection:text-true-black overflow-x-hidden">
		<!-- Noise Overlay -->
		<div class="fixed inset-0 z-[9999] opacity-[0.03] pointer-events-none bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
		
		<!-- Background Gradient -->
		<div class="fixed inset-0 -z-10 bg-true-black">
			<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-neon-cyan opacity-[0.05] blur-[120px]"></div>
			<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-neon-cyan opacity-[0.03] blur-[120px]"></div>
		</div>

		<slot />
	</body>
</html>
