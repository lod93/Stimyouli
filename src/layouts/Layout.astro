---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Stimyouli Group - Software Engineering & Infrastructure" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Stimyouli Group</title>
    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;800&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased selection:bg-neon-cyan selection:text-true-black overflow-x-hidden">
    <div class="fixed inset-0 -z-10 bg-true-black">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,_#00f2ff10_0%,_transparent_50%)]"></div>
    </div>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--accent: 0, 242, 255;
		--accent-light: 100, 245, 255;
		--accent-dark: 0, 163, 173;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
</style>
