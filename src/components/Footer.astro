---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-true-black border-t border-white/5 py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-16">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-xl bg-neon-cyan flex items-center justify-center shadow-[0_0_20px_rgba(0,242,255,0.2)]">
            <span class="text-true-black font-bold text-xl">S</span>
          </div>
          <span class="font-display text-2xl font-black tracking-tighter text-white">STIMYOULI</span>
        </div>
        <p class="text-gray-500 max-w-sm mb-8 leading-relaxed">
          Cairo-based engineering and infrastructure powerhouse building scalable web systems, SaaS platforms, and cloud services.
        </p>
      </div>
      
      <div>
        <h4 class="text-white font-bold mb-8 uppercase tracking-widest text-xs opacity-50">Resources</h4>
        <ul class="space-y-4">
          <li><a href={`${base}/services`} class="text-gray-400 hover:text-neon-cyan transition-colors">Services</a></li>
          <li><a href={`${base}/portfolio`} class="text-gray-400 hover:text-neon-cyan transition-colors">Portfolio</a></li>
          <li><a href={`${base}/company-profile`} class="text-gray-400 hover:text-neon-cyan transition-colors">Company Profile</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-bold mb-6">Connect</h4>
        <ul class="space-y-4">
          <li><a href="mailto:info@stimyouli.com" class="text-gray-400 hover:text-neon-cyan transition-colors">info@stimyouli.com</a></li>
          <li><a href="https://stimyouli.com" class="text-gray-400 hover:text-neon-cyan transition-colors">stimyouli.com</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} Stimyouli Group. All rights reserved.
      </p>
      <div class="flex gap-6">
        <span class="text-gray-500 text-sm">Cairo, Egypt</span>
      </div>
    </div>
  </div>
</footer>
