---
const currentYear = new Date().getFullYear();
---

<footer class="bg-true-black border-t border-white/5 py-12 mt-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-8 h-8 rounded-lg bg-neon-cyan flex items-center justify-center">
            <span class="text-true-black font-bold text-xl">S</span>
          </div>
          <span class="font-display text-xl font-bold tracking-tighter text-white">STIMYOULI</span>
        </div>
        <p class="text-gray-400 max-w-sm mb-6">
          Cairo-based engineering and infrastructure powerhouse building scalable web systems, SaaS platforms, and cloud services.
        </p>
      </div>
      
      <div>
        <h4 class="text-white font-bold mb-6">Resources</h4>
        <ul class="space-y-4">
          <li><a href="/stimyouli-public-repo/services" class="text-gray-400 hover:text-neon-cyan transition-colors">Services</a></li>
          <li><a href="/stimyouli-public-repo/portfolio" class="text-gray-400 hover:text-neon-cyan transition-colors">Portfolio</a></li>
          <li><a href="/stimyouli-public-repo/company-profile" class="text-gray-400 hover:text-neon-cyan transition-colors">Company Profile</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-bold mb-6">Connect</h4>
        <ul class="space-y-4">
          <li><a href="mailto:info@stimyouli.com" class="text-gray-400 hover:text-neon-cyan transition-colors">info@stimyouli.com</a></li>
          <li><a href="https://stimyouli.com" class="text-gray-400 hover:text-neon-cyan transition-colors">stimyouli.com</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">
        &copy; {currentYear} Stimyouli Group. All rights reserved.
      </p>
      <div class="flex gap-6">
        <span class="text-gray-500 text-sm">Cairo, Egypt</span>
      </div>
    </div>
  </div>
</footer>
