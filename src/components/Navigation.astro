---
const base = import.meta.env.BASE_URL;
const navItems = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/services`, label: 'Services' },
  { href: `${base}/portfolio`, label: 'Portfolio' },
  { href: `${base}/company-profile`, label: 'Profile' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-true-black/90 backdrop-blur-xl border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-3 group">
      <img src="https://stimyouli.com/wp-content/uploads/2024/04/stimyouli-dark-logo.png" alt="Stimyouli Group" class="h-12 w-auto object-contain" />
    </a>
    
    <div class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-sm font-medium text-gray-400 hover:text-neon-cyan transition-colors"
        >
          {item.label}
        </a>
      ))}
      <a 
        href="mailto:info@stimyouli.com" 
        class="bg-neon-cyan text-true-black px-5 py-2 rounded-full text-sm font-bold hover:bg-white transition-colors"
      >
        Contact
      </a>
    </div>
  </div>
</nav>

<div class="h-20"></div>
